      "label": "Padding horizontal carte mobile",
      "default": 22
    },
    {
      "type": "range",
      "id": "card_padding_vertical_mobile",
      "min": 8,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Padding vertical carte mobile",
      "default": 24
    },
    {
      "type": "range",
