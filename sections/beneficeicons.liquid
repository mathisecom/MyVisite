{% style %}
  #shopify-section-{{ section.id }} .qb-benefits-section {
    background: {{ section.settings.section_bg }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  }

  #shopify-section-{{ section.id }} .qb-benefits-wrapper {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding-left: {{ section.settings.side_padding_desktop }}px;
    padding-right: {{ section.settings.side_padding_desktop }}px;
  }

  #shopify-section-{{ section.id }} .qb-benefits-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: {{ section.settings.gap_desktop }}px;
  }

  #shopify-section-{{ section.id }} .qb-benefit-card {
    background: {{ section.settings.card_bg }};
    border-radius: {{ section.settings.card_radius }}px;
    padding: {{ section.settings.card_padding_vertical_desktop }}px {{ section.settings.card_padding_horizontal_desktop }}px;
    min-height: {{ section.settings.card_min_height_desktop }}px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} .qb-benefit-icon-box {
    width: {{ section.settings.icon_box_size }}px;
    height: {{ section.settings.icon_box_size }}px;
    border-radius: {{ section.settings.icon_box_radius }}px;
    background: {{ section.settings.icon_box_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: {{ section.settings.icon_spacing_bottom }}px;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .qb-benefit-icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    color: {{ section.settings.icon_color }};
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .qb-benefit-title {
    margin: 0 0 {{ section.settings.title_spacing_bottom }}px;
    font-size: {{ section.settings.title_size_desktop }}px;
    line-height: {{ section.settings.title_line_height_desktop | times: 0.1 }};
    font-weight: {{ section.settings.title_weight }};
    color: {{ section.settings.title_color }};
    letter-spacing: {{ section.settings.title_letter_spacing | times: 0.01 }}em;
  }

  #shopify-section-{{ section.id }} .qb-benefit-text {
    margin: 0;
    font-size: {{ section.settings.text_size_desktop }}px;
    line-height: {{ section.settings.text_line_height_desktop | times: 0.1 }};
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .qb-benefit-text p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .qb-benefit-text strong {
    color: {{ section.settings.bold_color }};
    font-weight: {{ section.settings.bold_weight }};
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .qb-benefits-wrapper {
      padding-left: {{ section.settings.side_padding_tablet }}px;
      padding-right: {{ section.settings.side_padding_tablet }}px;
    }

    #shopify-section-{{ section.id }} .qb-benefits-grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, minmax(0, 1fr));
      gap: {{ section.settings.gap_tablet }}px;
    }

    #shopify-section-{{ section.id }} .qb-benefit-card {
      min-height: {{ section.settings.card_min_height_tablet }}px;
      padding: {{ section.settings.card_padding_vertical_tablet }}px {{ section.settings.card_padding_horizontal_tablet }}px;
    }

    #shopify-section-{{ section.id }} .qb-benefit-title {
      font-size: {{ section.settings.title_size_tablet }}px;
      line-height: {{ section.settings.title_line_height_tablet | times: 0.1 }};
    }

    #shopify-section-{{ section.id }} .qb-benefit-text {
      font-size: {{ section.settings.text_size_tablet }}px;
      line-height: {{ section.settings.text_line_height_tablet | times: 0.1 }};
    }
  }

  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .qb-benefits-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .qb-benefits-wrapper {
      max-width: 100%;
      margin: 0;
      padding-left: 0;
      padding-right: 0;
    }

    #shopify-section-{{ section.id }} .qb-benefits-grid {
      display: flex;
      gap: {{ section.settings.gap_mobile }}px;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-left: 0;
      padding-right: 0;
      scrollbar-width: none;
    }

    #shopify-section-{{ section.id }} .qb-benefits-grid::-webkit-scrollbar {
      display: none;
    }

    #shopify-section-{{ section.id }} .qb-benefit-card {
      flex: 0 0 {{ section.settings.mobile_card_width }}%;
      width: {{ section.settings.mobile_card_width }}%;
      min-width: {{ section.settings.mobile_card_width }}%;
      scroll-snap-align: start;
      border-radius: {{ section.settings.card_radius_mobile }}px;
      min-height: {{ section.settings.card_min_height_mobile }}px;
      padding: {{ section.settings.card_padding_vertical_mobile }}px {{ section.settings.card_padding_horizontal_mobile }}px;
    }

    #shopify-section-{{ section.id }} .qb-benefit-icon-box {
      width: {{ section.settings.icon_box_size_mobile }}px;
      height: {{ section.settings.icon_box_size_mobile }}px;
      border-radius: {{ section.settings.icon_box_radius_mobile }}px;
      margin-bottom: {{ section.settings.icon_spacing_bottom_mobile }}px;
    }

    #shopify-section-{{ section.id }} .qb-benefit-icon {
      width: {{ section.settings.icon_size_mobile }}px;
      height: {{ section.settings.icon_size_mobile }}px;
    }

    #shopify-section-{{ section.id }} .qb-benefit-title {
      margin-bottom: {{ section.settings.title_spacing_bottom_mobile }}px;
      font-size: {{ section.settings.title_size_mobile }}px;
      line-height: {{ section.settings.title_line_height_mobile | times: 0.1 }};
    }

    #shopify-section-{{ section.id }} .qb-benefit-text {
      font-size: {{ section.settings.text_size_mobile }}px;
      line-height: {{ section.settings.text_line_height_mobile | times: 0.1 }};
    }
  }
{% endstyle %}

<section class="qb-benefits-section">
  <div class="qb-benefits-wrapper">
    <div class="qb-benefits-grid">
      {% for block in section.blocks %}
        <div class="qb-benefit-card" {{ block.shopify_attributes }}>
          <div class="qb-benefit-icon-box">
            {% case block.settings.icon %}
              {% when 'rocket' %}
                <svg class="qb-benefit-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M14.5 4.5C17 4 19.5 4.5 19.5 4.5C19.5 4.5 20 7 19.5 9.5C19.1 11.6 17.7 13.1 16 14.5L9.5 8C10.9 6.3 12.4 4.9 14.5 4.5Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M9.5 8L6.5 8.5L4.5 10.5L8 11.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M16 14.5L15.5 17.5L13.5 19.5L12.5 16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M8.5 12.5L5.5 15.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M7.5 16.5C7.5 16.5 7 18 5.5 19C4.2 19.9 2.5 20 2.5 20C2.5 20 2.6 18.3 3.5 17C4.5 15.5 6 15 6 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>

              {% when 'scan' %}
                <svg class="qb-benefit-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M8 4H5C4.45 4 4 4.45 4 5V8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M16 4H19C19.55 4 20 4.45 20 5V8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M8 20H5C4.45 20 4 19.55 4 19V16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M16 20H19C19.55 20 20 19.55 20 19V16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <rect x="8" y="8" width="8" height="8" rx="2" stroke="currentColor" stroke-width="1.8"/>
                </svg>

              {% when 'arrow' %}
                <svg class="qb-benefit-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M4 16L10 10L14 14L20 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M15 8H20V13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>

              {% when 'bars' %}
                <svg class="qb-benefit-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M4 20H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <rect x="6" y="11" width="3" height="7" rx="1" stroke="currentColor" stroke-width="1.8"/>
                  <rect x="11" y="7" width="3" height="11" rx="1" stroke="currentColor" stroke-width="1.8"/>
                  <rect x="16" y="4" width="3" height="14" rx="1" stroke="currentColor" stroke-width="1.8"/>
                </svg>
            {% endcase %}
          </div>

          <h3 class="qb-benefit-title">{{ block.settings.title }}</h3>
          <div class="qb-benefit-text">{{ block.settings.text }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cartes bénéfices slider",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "label": "Largeur maximale",
      "default": 1600
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Colonnes desktop",
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Colonnes tablette",
      "default": 2
    },
    {
      "type": "range",
      "id": "mobile_card_width",
      "min": 70,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Largeur des cartes mobile",
      "default": 85
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Espace entre les cartes desktop",
      "default": 18
    },
    {
      "type": "range",
      "id": "gap_tablet",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Espace entre les cartes tablette",
      "default": 16
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Espace entre les cartes mobile",
      "default": 12
    },
    {
      "type": "header",
      "content": "Espacement section"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding haut desktop",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bas desktop",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding haut mobile",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding bas mobile",
      "default": 24
    },
    {
      "type": "range",
      "id": "side_padding_desktop",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Marge latérale desktop",
      "default": 20
    },
    {
      "type": "range",
      "id": "side_padding_tablet",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Marge latérale tablette",
      "default": 16
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Fond de section",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fond des cartes",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "icon_box_bg",
      "label": "Fond du bloc icône",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Couleur icône",
      "default": "#d61f93"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur titre",
      "default": "#061a2f"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur texte",
      "default": "#59697c"
    },
    {
      "type": "color",
      "id": "bold_color",
      "label": "Couleur texte en gras",
      "default": "#3b4b5d"
    },
    {
      "type": "header",
      "content": "Cartes"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Arrondi cartes desktop",
      "default": 18
    },
    {
      "type": "range",
      "id": "card_radius_mobile",
      "min": 0,
      "max": 40,
