      "unit": "px",
      "label": "Arrondi cartes mobile",
      "default": 18
    },
    {
      "type": "range",
      "id": "card_padding_horizontal_desktop",
      "min": 8,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding horizontal carte desktop",
      "default": 40
    },
    {
      "type": "range",
      "id": "card_padding_vertical_desktop",
      "min": 8,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding vertical carte desktop",
