    },
    {
      "type": "range",
      "id": "text_size_tablet",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Taille texte tablette",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Taille texte mobile",
      "default": 15
    },
    {
      "type": "range",
      "id": "text_line_height_desktop",
      "min": 10,
      "max": 24,
      "step": 1,
      "label": "Interligne texte desktop (x10)",
      "default": 15
    },
    {
      "type": "range",
      "id": "text_line_height_tablet",
      "min": 10,
      "max": 24,
      "step": 1,
      "label": "Interligne texte tablette (x10)",
      "default": 15
    },
    {
      "type": "range",
      "id": "text_line_height_mobile",
      "min": 10,
      "max": 24,
      "step": 1,
      "label": "Interligne texte mobile (x10)",
      "default": 15
    },
    {
      "type": "range",
      "id": "bold_weight",
      "min": 400,
      "max": 900,
      "step": 100,
      "label": "Graisse texte en gras",
